# Voice of Consumer OS - 环境配置
# 复制此文件到 fullstack/.env 并填入真实值

# 应用监听地址和端口（生产环境保持 127.0.0.1，由 Nginx 反代）
VOC_HOST=127.0.0.1
VOC_PORT=8090

# 生产域名
VOC_PUBLIC_HOSTNAME=vocosai.com
VOC_PUBLIC_ALIASES=www.vocosai.com

# AI 提供商配置
# 填你的 API Key，留空则使用本地兜底编排（功能受限）
# DeepSeek:   PROVIDER=deepseek,   MODEL=deepseek-chat
# OpenAI:     PROVIDER=openai,     MODEL=gpt-4o-mini
# 通义千问:   PROVIDER=qwen,      MODEL=qwen-turbo
VOC_AI_PROVIDER=deepseek
VOC_AI_MODEL=deepseek-chat
VOC_AI_API_KEY=your_api_key_here

# 自定义 OpenAI 兼容提供商可通过 UI 设置页面配置，
# 或将 API Key 填在上面，在数据库设置页面选择对应模型。
