# Copy this file to fullstack/.env and fill in real secrets.
VOC_HOST=127.0.0.1
VOC_PORT=8090

# Public hostname routed by Cloudflare Tunnel.
VOC_PUBLIC_HOSTNAME=vocos.meetmore.cc
VOC_PUBLIC_ALIASES=www.vocos.meetmore.cc

# AI provider config. Leave VOC_AI_API_KEY empty to use the local fallback orchestration.
VOC_AI_PROVIDER=deepseek
VOC_AI_MODEL=deepseek-chat
VOC_AI_API_KEY=

# For custom OpenAI-compatible providers, set provider/custom model through the UI,
# or store the provider API key above and use the database settings page.
